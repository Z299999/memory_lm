# Exp0404 runs:
# - default: ignore all concrete run artifacts
# - keep runs/log.md tracked
# - if a future run is worth keeping, unignore it explicitly, e.g.
#   !exp0404_three_world/runs/good_run_001/
#   !exp0404_three_world/runs/good_run_001/**
exp0404_three_world/runs/*
!exp0404_three_world/runs/log.md
!exp0404_three_world/runs/orthfall_frontier_001/
!exp0404_three_world/runs/orthfall_frontier_001/**
!exp0404_three_world/runs/confluence_002/
!exp0404_three_world/runs/confluence_002/**
__pycache__/
*.pyc
.env
.env.local
exp0404_three_world/models/*.local.md

# Exp0406 - ignore large checkpoint files only (data is important, track it!)
exp0406_distil/models/student/checkpoint-*/
exp0406_distil/models/student/final/

# Exp0408 - ignore model weights (too large for git), see models/README.md for download instructions
exp0408_memory_backprop/models/student/
# Exp0408 - ignore run artifacts by default; unignore specific runs worth keeping
exp0408_memory_backprop/runs/
# Exp0408 - ignore generated plots (reproducible from model + runs)
exp0408_memory_backprop/plots/

# Exp0410 - ignore run artifacts
exp0410_triangleNet/runs/

# Exp0414 - ignore LaTeX auxiliary files (keep .tex, .bib, and .pdf)
*.aux
*.log
*.out
*.synctex.gz
*.fdb_latexmk
*.fls
*.bbl
*.blg

