# Runs:
# - default: ignore all concrete run artifacts
# - keep runs/log.md tracked
# - if a future run is worth keeping, unignore it explicitly, e.g.
#   !runs/good_run_001/
#   !runs/good_run_001/**
runs/*
!runs/log.md
!runs/orthfall_frontier_001/
!runs/orthfall_frontier_001/**
__pycache__/
*.pyc
.env
.env.local
models/*.local.md

# Exp0406 - ignore large checkpoint and data files
exp0406_distil/models/student/checkpoint-*/
exp0406_distil/models/student/final/
exp0406_distil/data/generated/*.jsonl
