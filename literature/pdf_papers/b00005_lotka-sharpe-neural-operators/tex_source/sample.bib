  booktitle = {2021 {{IEEE}} 4th {{International Conference}} on {{Soft Robotics}} ({{RoboSoft}})},
  author = {{der Maur}, Pascal Auf and Djambazi, Betim and Haberth{\"u}r, Yves and H{\"o}rmann, Patricia and K{\"u}bler, Alexander and Lustenberger, Michael and Sigrist, Samuel and Vigen, Oda and F{\"o}rster, Julian and Achermann, Florian and Hampp, Elias and Katzschmann, Robert K. and Siegwart, Roland},
  year = {2021},
  month = apr,
  pages = {15--20},
  doi = {10.1109/RoboSoft51838.2021.9479192},
  urldate = {2025-08-15},
  abstract = {RoBoa is a vine-like search and rescue robot that can explore narrow and cluttered environments such as destroyed buildings. The robot assists rescue teams in finding and communicating with trapped people. It employs the principle of vine robots for locomotion, everting the tip of its tube to move forward. Inside the tube, pneumatic actuators enable lateral movement. The head carries sensors and is mounted outside at the tip of the tube. At the back, a supply box contains the rolled up tube and provides pressurized air, power, computation, as well as an interface for the user to interact with the system. A decentralized control scheme was implemented that reduces the required number of cables and takes care of the low-level control of the pneumatic actuators. The design, characterization, and experimental evaluation of the system and its crucial components is shown. The complete prototype is fully functional and was evaluated in a realistic environment of a collapsed building where the remote-controlled robot was able to repeatedly locate a trapped person after a travel distance of about 10m.},
  file = {/Users/cveil/Documents/Research/Zotero/storage/GTNPEEVA/der Maur et al. - 2021 - RoBoa Construction and Evaluation of a Steerable Vine Robot for Search and Rescue Applications.pdf}
}

