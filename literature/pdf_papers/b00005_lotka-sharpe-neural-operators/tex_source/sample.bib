@article{jin2023Recent,
  title = {Recent {{Advances}} and {{Applications}} of {{Machine Learning}} in {{Experimental Solid Mechanics}}: {{A Review}}},
  shorttitle = {Recent {{Advances}} and {{Applications}} of {{Machine Learning}} in {{Experimental Solid Mechanics}}},
  author = {Jin, Hanxun and Zhang, Enrui and Espinosa, Horacio D.},
  year = {2023},
