@article{yu2022Gradientenhanced,
  title = {Gradient-Enhanced Physics-Informed Neural Networks for Forward and Inverse {{PDE}} Problems},
  author = {Yu, Jeremy and Lu, Lu and Meng, Xuhui and Karniadakis, George Em},
  year = {2022},
