  author = {Song, Wenxiang and Jiang, Shijie and {Camps-Valls}, Gustau and Williams, Mathew and Zhang, Lu and Reichstein, Markus and Vereecken, Harry and He, Leilei and Hu, Xiaolong and Shi, Liangsheng},
  year = {2024},
