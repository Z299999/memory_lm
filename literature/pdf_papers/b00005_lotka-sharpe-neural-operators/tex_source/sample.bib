@misc{qin20253D,
  title = {{{3D Steering}} and {{Localization}} in {{Pipes}} and {{Burrows}} Using an {{Externally Steered Soft Growing Robot}}},
  author = {Qin, Yimeng and Grinberg, Jared and Heap, William and Okamura, Allison M.},
