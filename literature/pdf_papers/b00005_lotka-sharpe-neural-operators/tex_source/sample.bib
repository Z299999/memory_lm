@article{fang2022Efficient,
  title = {Efficient {{Jacobian-Based Inverse Kinematics With Sim-to-Real Transfer}} of {{Soft Robots}} by {{Learning}}},
  author = {Fang, Guoxin and Tian, Yingjun and Yang, Zhi-Xin and Geraedts, Jo M. P. and Wang, Charlie C. L.},
