@article{yang2023PhysicsInformed,
  title = {Physics-{{Informed Neural Network}} for {{Model Prediction}} and {{Dynamics Parameter Identification}} of {{Collaborative Robot Joints}}},
  author = {Yang, Xingyu and Du, Yixiong and Li, Leihui and Zhou, Zhengxue and Zhang, Xuping},
