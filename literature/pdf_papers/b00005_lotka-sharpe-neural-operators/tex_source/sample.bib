@article{mengaldo2022concise,
  title = {A Concise Guide to Modelling the Physics of Embodied Intelligence in Soft Robotics},
  author = {Mengaldo, Gianmarco and Renda, Federico and Brunton, Steven L. and B{\"a}cher, Moritz and Calisti, Marcello and Duriez, Christian and Chirikjian, Gregory S. and Laschi, Cecilia},
