@misc{naderi2025PhysicsInformed,
  type = {{{SSRN Scholarly Paper}}},
  title = {A {{Physics-Informed Neural Network Model}} to {{Predict Thermo-Oxidative}}/{{Thermal Aging}} of {{Viscoelastic Materials}}},
  author = {Naderi, Hossein and Dargazany, Roozbeh},
  year = {2025},
  month = may,
  number = {5255540},
  eprint = {5255540},
  publisher = {Social Science Research Network},
  address = {Rochester, NY},
  doi = {10.2139/ssrn.5255540},
  urldate = {2025-05-29},
  abstract = {This study presents a novel physics-informed multi-agent constitutive model designed to predict the viscoelastic materials' (VEMs) behavior and their degradation in mechanical performance during thermal-oxidative (TO) aging. The molecular chain network of VEMs can be simplified into an elastic chain network and free chain network, which is described by the architecture of the eight-chain model. The environmental factors induce progressive damage to the polymer matrix over time, driven by extensive chain scission, chain formation, and alterations in the molecular arrangement within the polymer structure. A physics-informed data-driven model is proposed to reflect the mechanical properties of TO aged VEMs, in which the physics-informed neural network (PINN) theory is incorporated to describe the statistical characteristics of molecular chains and the reaction rate of TO aging. Based on the interpretation of the microscopic mechanism, the above-mentioned network alterations during aging were considered in the model. The complex 3D stress-strain tensor mapping problem has been simplified into a series of super-constrained 1D mapping problems through sequential order reduction. This reduction is achieved using an ensemble of replicated conditional neural network learning agents, each specifically trained to decompose the high-dimensional mapping into distinct 1D problems, each representing a specialized agent. The rheology of the model consists of two parts, including the effect of aging on the hyperelastic part and the influence of aging on the viscous part of the rheological model. The proposed model has been benchmarked against various experimental data from the literature. The model's thermodynamic consistency has been rigorously verified. The verifications demonstrate that the proposed model exhibits high accuracy in characterizing the mechanical behavior of viscoelastic materials (VEMs) across various aging levels.},
  archiveprefix = {Social Science Research Network},
  langid = {english},
  file = {/Users/cveil/Documents/Research/Zotero/storage/7EQJX4AI/Naderi and Dargazany - 2025 - A Physics-Informed Neural Network Model to Predict Thermo-OxidativeThermal Aging of Viscoelastic Ma.pdf}
}

@misc{nadizar2022Collective,
