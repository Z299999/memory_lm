@misc{yin2025Physicsinformed,
  title = {Physics-Informed {{Neural Networks Enable High Fidelity Shear Wave Viscoelastography}} across {{Multiple}} Organs},
  author = {Yin, Ziying and Guo, Yuxi and Pu, Jiayi and Jiang, Yuxuan and Ma, Shiyu and Li, Guo-Yang and Cao, Yanping},
  year = {2025},
  month = may,
  number = {arXiv:2505.03935},
