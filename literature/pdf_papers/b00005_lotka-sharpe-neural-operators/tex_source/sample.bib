  abstract = {Learning systems based on Deep Neural Networks (DNNs) have proven to be able to learn effectively when provided with massive amounts of data. However, in many engineering applications e.g., automated assembly/disassembly factories, robotic assistants interacting with humans, manipulation systems used in environments where human intervention is problematic or not possible, etc, the available amounts of data are limited and the processes are often running in real-time. To adapt learning systems based on DNNs to such cases, some researchers are developing so called Physics-Informed Neural Networks (PINNs). PINNs use knowledge about a physical system, such as its governing state equations, to improve the accuracy and speed of learning systems when comparatively low amount of data are available. This is mainly achieved by reducing the search space of the optimization procedures utilized to determine the weights of the networks which minimize the expected loss on the training and test dataset. In this review, we analyze the state-of-the-art in PINNs starting with general approaches, then focus on robotics and discuss the challenges, open problems, and future directions of PINNs research in robotics. Furthermore, this survey provides an extensive comparison of state-of-the-art physics-informed approaches based on learning for robotic systems, classifying them by different properties. Finally, we discuss the challenges and future directions, highlighting the need for new learning systems capable of generalizing on limited amounts of data and working in real time, in order to facilitate substantial advancements in engineering and in particular in robotics applications.},
  archiveprefix = {Social Science Research Network},
  langid = {english},
  keywords = {Deep neural network,Loss function,Physics-informed neural networks,review,Robotics},
  file = {/Users/cveil/Documents/Research/Zotero/storage/FA49X6WW/Sivtsov et al. - 2025 - Physics-Informed Neural Networks in Robotics A Review.pdf}
}

