@article{lin2023Modeling,
  title = {Modeling and {{Control}} of a {{Soft Robotic Fish}} with {{Integrated Soft Sensing}}},
  author = {Lin, Yu-Hsiang and Siddall, Robert and Schwab, Fabian and Fukushima, Toshihiko and Banerjee, Hritwick and Baek, Youngjoon and Vogt, Daniel and Park, Yong-Lae and Jusufi, Ardian},
