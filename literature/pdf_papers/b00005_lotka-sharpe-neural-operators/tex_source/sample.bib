@article{kalibala2025Realtime,
  title = {Real-Time Force/Position Control of Soft Growing Robots: {{A}} Data-Driven Model Predictive Approach},
  shorttitle = {Real-Time Force/Position Control of Soft Growing Robots},
  author = {Kalibala, Abdonoor and Nada, Ayman A. and Ishii, Hiroyuki and {El-Hussieny}, Haitham},
