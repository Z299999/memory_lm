@article{huang2025Grasping,
  title = {Grasping by Spiraling: Reproducing Elephant Movements with Rigid-Soft Robot Synergy},
  shorttitle = {Grasping by Spiraling},
  author = {Huang, Huishi and Wang, Haozhe and Fang, Chongyu and Yan, Mingge and Xu, Ruochen and Zhang, Yiyuan and Wang, Zhanchi and Ying, Fengkang and Liu, Jun and Laschi, Cecilia and Ang Jr, Marcelo H.},
  year = {2025},
